# ─────────────────────────────────────────────
#  THE-MACHINE  –  Environment Variables
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id_or_group_id

# ── SEC EDGAR ─────────────────────────────────
# Public API, no key required, but identify yourself
EDGAR_USER_AGENT="YourName yourname@email.com"
# Polling interval in seconds (min recommended: 60)
EDGAR_POLL_INTERVAL=60

# ── USAspending.gov ───────────────────────────
# Free public API – no key required
USASPENDING_POLL_INTERVAL=300

# ── Google Drive Export ───────────────────────
# Path to your service account JSON downloaded from GCP Console
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json
# Google Drive folder ID where exports are saved
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id

# ── Database ──────────────────────────────────
DB_PATH=data/the_machine.db

# ── Risk Controls (kill switch) ───────────────
# Stop loss per position (e.g. 0.15 = -15%)
STOP_LOSS_PCT=0.15
# Max monthly drawdown before auto-pause (e.g. 0.20 = -20%)
MAX_MONTHLY_DRAWDOWN=0.20
# Pause duration in days after max drawdown breach
DRAWDOWN_PAUSE_DAYS=30

# ── Scoring thresholds ────────────────────────
# Minimum score (0-100) to emit an alert
MIN_ALERT_SCORE=60
# Score required to escalate to STRONG BUY tier
STRONG_BUY_THRESHOLD=80

# ── Serenity / tweet archive ──────────────────
# Local path OR GitHub raw URL to serenity tweet CSV/JSON
SERENITY_ARCHIVE_PATH=data/serenity_tweets.json
# How many days back to consider a serenity mention recent
SERENITY_RECENCY_DAYS=30

# ── yfinance cache ────────────────────────────
# Seconds before refreshing fundamentals data
FUNDAMENTALS_CACHE_TTL=3600

# ── Interactive Brokers ──────────────────────────────────────
# Host IB Gateway / TWS (quasi sempre localhost)
IBKR_HOST=127.0.0.1
# Porta: TWS paper=7497 | TWS live=7496 | Gateway paper=4002 | Gateway live=4001
IBKR_PORT=7497
# clientId univoco per questo processo API (non usare lo stesso di altre app connesse)
IBKR_CLIENT_ID=10
# Account specifico (opzionale; lascia vuoto per account principale)
IBKR_ACCOUNT=
# Timeout connessione in secondi
IBKR_CONNECT_TIMEOUT=20
# Secondi di attesa prima del primo retry su disconnessione (raddoppia, cap 300s)
IBKR_RECONNECT_DELAY=30
# Max tentativi riconnessione prima di loggare CRITICAL e fermarsi
IBKR_MAX_RETRIES=10
# Intervallo sync posizioni nel daemon loop (secondi)
IBKR_SYNC_INTERVAL=60
# DRY_RUN=true -> stop loss loggati ma NON inviati. Metti false solo in produzione!
IBKR_DRY_RUN=true

# ── Hogue Framework ───────────────────────────
# Chiudi covered call se catturato >= questa % del premio (default 50%)
HOGUE_EARLY_CLOSE_PCT=0.50
# Regola 21-DTE: chiudi se catturato>=50% E giorni a scadenza <= questo
HOGUE_DTE_THRESHOLD=21
# Massimo roll consentiti per posizione prima di lasciare assegnare
HOGUE_MAX_ROLLS=2
# Roll: valuta roll se stock_price > strike * questa soglia (0.97 = a -3%)
HOGUE_ROLL_TRIGGER_PCT=0.97
# IV Rank minimo per vendere calls (sotto = skip ciclo con notifica)
HOGUE_MIN_IV_RANK=20.0
# IV Rank oltre cui si attiva Iron Condor e strike più OTM
HOGUE_HIGH_IV_RANK=80.0
# Calo settimanale massimo prima di bloccare vendita calls (0.10 = -10%)
HOGUE_WEEKLY_DROP_BLOCK=0.10
# Giorni da earnings entro cui bloccare automaticamente la vendita di calls
HOGUE_EARNINGS_BUFFER_DAYS=7
# Profitto su stock che triggera il Collar automatico (0.20 = +20%)
HOGUE_COLLAR_TRIGGER_PCT=0.20
# Costo netto Collar sotto cui segnalare come protezione quasi gratuita ($)
HOGUE_FREE_COLLAR_THRESHOLD=0.05
# Target cicli/anno per annualizzazione (Hogue: 15-16)
HOGUE_TARGET_CYCLES_YEAR=16
# DTE target per selezione scadenza opzioni (giorni)
HOGUE_TARGET_DTE=35
